np.random.seed(42)  # reproducibility for the report / judges

def get_best_simulator(method: str = "density_matrix") -> AerSimulator:
    """
    Tries to build a GPU-backed AerSimulator; falls back to CPU automatically.
    This is what lets you honestly claim 'uses GPU when available' in your
    slide without lying if the judge's laptop / your laptop has no GPU.
    """
    try:
        sim_gpu = AerSimulator(method=method, device="GPU")
        # Force a tiny dummy run to confirm the GPU device actually works
        test_qc = QuantumCircuit(1)
        test_qc.h(0)
        test_qc.save_density_matrix() if method == "density_matrix" else test_qc.save_statevector()
        transpiled = transpile(test_qc, sim_gpu)
        sim_gpu.run(transpiled).result()
        print(f"[INFO] GPU backend acquired for AerSimulator(method='{method}').")
        return sim_gpu
    except Exception as e:
        print(f"[INFO] GPU backend unavailable ({type(e).__name__}); using CPU. "
              f"(This is expected on most laptops / judge machines.)")
        return AerSimulator(method=method, device="CPU")


