# MODULE: REUSABLE ENTANGLEMENT LAB  (this is your "reusable entanglement module" deliverable)
# ------------------------------------------------------------------------------
class EntanglementLab:
    """
    Reusable, importable module for:
        - generating Bell pairs
        - injecting realistic channel noise (depolarizing + amplitude damping)
        - measuring CHSH correlation statistics
        - measuring entanglement decay (concurrence) under noise
        - running a discrete-variable quantum-illumination-style detection task
          against a fair classical baseline

    Import this class in any other notebook with:
        from qt16_simulation import EntanglementLab
    """

    def __init__(self, simulator: AerSimulator = None):
        self.sim = simulator or get_best_simulator("density_matrix")

    # ---------- 1. Bell pair generation ----------
    @staticmethod
    def bell_circuit() -> QuantumCircuit:
        """
        Builds |Phi+> = (|00> + |11>)/sqrt(2) with qubit0 = idler, qubit1 = signal.
        An explicit id() is placed on the signal qubit right after entanglement --
        this is the physical stand-in for "the signal qubit travels through the
        channel" and is exactly where our noise model below injects loss/clutter.
        (Without an explicit gate here, a noise model attached only to qubit 1
        would never fire, since qubit 1 otherwise only ever appears as the
        *target* of the CX gate.)
        """
        qc = QuantumCircuit(2, name="BellPair")
        qc.h(0)
        qc.cx(0, 1)
        qc.id(1)  # <-- channel-transit marker for the signal qubit; noise attaches here
        return qc

    # ---------- 2. Noise channel builder ----------
    @staticmethod
    def build_noise_model(depol_p: float, amp_damp_gamma: float, noisy_qubit: int = 1) -> NoiseModel:
        """
        depol_p        : depolarizing probability (models random scattering / clutter)
        amp_damp_gamma : amplitude-damping parameter (models photon loss / target reflectivity loss)
        noisy_qubit    : which physical qubit picks up the noise (the transmitted 'signal' qubit)
        """
        noise_model = NoiseModel()

        depol_err = depolarizing_error(depol_p, 1)
        amp_err = amplitude_damping_error(amp_damp_gamma)

        # Compose both error channels onto the same physical qubit
        combined_err = depol_err.compose(amp_err)

        noise_model.add_quantum_error(combined_err, ["id", "u1", "u2", "u3", "x", "ry", "rx"], [noisy_qubit])
        return noise_model

    # ---------- 3. CHSH correlation statistics ----------
    def measure_chsh(self, depol_p: float, amp_gamma: float, shots: int = 4096) -> float:
        """
        Runs the standard CHSH-Bell test using the optimal Tsirelson measurement
        angles: Alice in {0, pi/4}, Bob in {pi/8, 3*pi/8}.
        Returns the CHSH S value. |S| <= 2 is the classical bound.
        |S| <= 2*sqrt(2) ~= 2.828 is the quantum (Tsirelson) bound.
        """
        angle_pairs = [(0, np.pi / 8), (0, 3 * np.pi / 8),
                       (np.pi / 4, np.pi / 8), (np.pi / 4, 3 * np.pi / 8)]
        signs = [+1, -1, +1, +1]  # standard CHSH combination E00 - E01 + E10 + E11

        noise_model = self.build_noise_model(depol_p, amp_gamma)
        correlators = []

        for (a_angle, b_angle) in angle_pairs:
            qc = self.bell_circuit()
            qc.ry(-2 * a_angle, 0)
            qc.ry(-2 * b_angle, 1)
            qc.measure_all()

            transpiled = transpile(qc, self.sim, optimization_level=0)
            result = self.sim.run(transpiled, noise_model=noise_model, shots=shots).result()
            counts = result.get_counts()

            total = sum(counts.values())
            e_value = 0.0
            for bitstring, n in counts.items():
                bits = bitstring.replace(" ", "")
                parity = 1 if bits.count("1") % 2 == 0 else -1
                e_value += parity * (n / total)
            correlators.append(e_value)

        s_value = sum(s * e for s, e in zip(signs, correlators))
        return abs(s_value)

    # ---------- 4. Entanglement decay (concurrence) ----------
    def measure_concurrence(self, depol_p: float, amp_gamma: float) -> float:
        """
        Runs the Bell circuit through the noisy channel using the density-matrix
        simulator and returns the exact Wootters concurrence of the resulting
        2-qubit mixed state. Concurrence = 0 means fully separable (no entanglement
        left); concurrence = 1 means maximally entangled.
        """
        qc = self.bell_circuit()
        qc.save_density_matrix()
        noise_model = self.build_noise_model(depol_p, amp_gamma)

        transpiled = transpile(qc, self.sim, optimization_level=0)
        result = self.sim.run(transpiled, noise_model=noise_model).result()
        rho = DensityMatrix(result.data(0)["density_matrix"])
        return float(concurrence(rho))

    # ---------- 5. Quantum illumination-style detection task ----------
    def quantum_detect(self, reflectivity: float, clutter_noise: float, shots: int = 4096) -> float:
        """
        Discrete-variable stand-in for quantum illumination:
        - An idler qubit is kept locally; a signal qubit is entangled with it and
          'sent out'.
        - If a target is present, the signal picks up loss = (1 - reflectivity)
          amplitude damping, and additional depolarizing clutter = clutter_noise.
        - If no target is present, the signal is fully randomized (pure clutter,
          amplitude damping = 1.0).
        - Receiver performs a joint Bell-basis measurement (CX + H) and checks how
          often it recovers the original |00> outcome -- this is the standard
          entanglement witness for a quantum-illumination-style receiver.
        Returns: probability of correctly witnessing entanglement (higher = easier
        to detect the target against the noise floor).
        """
        qc = self.bell_circuit()
        qc.cx(0, 1)
        qc.h(0)
        qc.measure_all()

        amp_gamma = 1.0 - reflectivity  # more reflective target -> less photon loss
        noise_model = self.build_noise_model(clutter_noise, amp_gamma)

        transpiled = transpile(qc, self.sim, optimization_level=0)
        result = self.sim.run(transpiled, noise_model=noise_model, shots=shots).result()
        counts = result.get_counts()
        total = sum(counts.values())
        # normalise bitstring keys (some Aer versions add spaces between registers)
        witness_counts = sum(n for b, n in counts.items() if b.replace(" ", "") == "00")
        return witness_counts / total

    # ---------- 6. Fair classical baseline (Monte Carlo, NOT a formula) ----------
    @staticmethod
    def classical_detect(reflectivity: float, clutter_noise: float,
                          n_trials: int = 20000) -> float:
        """
        Fair classical baseline: two classically-correlated bits (correlation
        strength = reflectivity, i.e. how much of the 'signal' bit survives to
        match the 'reference' bit) corrupted by the SAME clutter_noise bit-flip
        probability as the quantum channel above. This is simulated with an
        actual numpy Monte Carlo experiment (n_trials runs), not a closed-form
        curve, so it is directly comparable to the quantum result above.
        Returns: probability the classical receiver correctly matches signal
        to reference (its 'witness' probability, same units as quantum_detect).
        """
        reference_bits = np.random.randint(0, 2, size=n_trials)

        # signal starts as a copy of reference, then:
        #  (a) w.p. (1 - reflectivity) it gets randomized (target absorbs/misses photon)
        #  (b) after that, clutter_noise flips it independently (background clutter)
        signal_bits = reference_bits.copy()
        randomize_mask = np.random.rand(n_trials) > reflectivity
        signal_bits[randomize_mask] = np.random.randint(0, 2, size=randomize_mask.sum())

        flip_mask = np.random.rand(n_trials) < clutter_noise
        signal_bits[flip_mask] = 1 - signal_bits[flip_mask]

        matches = (signal_bits == reference_bits)
        return float(matches.mean())


