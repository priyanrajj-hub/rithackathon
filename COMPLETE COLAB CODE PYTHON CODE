# EXPERIMENT 1: CHSH CORRELATION STATISTICS vs. CHANNEL NOISE
# ------------------------------------------------------------------------------
def run_experiment_chsh(lab: EntanglementLab, noise_levels: np.ndarray):
    print("\n[Experiment 1] Measuring CHSH correlation statistics across noise levels...")
    chsh_values = []
    for p in noise_levels:
        s_val = lab.measure_chsh(depol_p=p, amp_gamma=p * 0.5, shots=4096)
        chsh_values.append(s_val)
        print(f"    depol_p={p:.3f}  ->  CHSH S = {s_val:.4f}")
    return np.array(chsh_values)


## %% [Cell 4] ----------------------------------------------------------------
# EXPERIMENT 2: ENTANGLEMENT (CONCURRENCE) DECAY UNDER NOISE
# ------------------------------------------------------------------------------
def run_experiment_concurrence(lab: EntanglementLab, noise_levels: np.ndarray):
    print("\n[Experiment 2] Measuring concurrence decay across noise levels...")
    concurrence_values = []
    for p in noise_levels:
        c_val = lab.measure_concurrence(depol_p=p, amp_gamma=p * 0.5)
        concurrence_values.append(c_val)
        print(f"    depol_p={p:.3f}  ->  Concurrence = {c_val:.4f}")
    return np.array(concurrence_values)


## %% [Cell 5] ----------------------------------------------------------------
# EXPERIMENT 3: QUANTUM vs CLASSICAL DETECTION ERROR PROBABILITY
# ------------------------------------------------------------------------------
def run_experiment_detection(lab: EntanglementLab, noise_range: np.ndarray, reflectivity: float = 0.15):
    print("\n[Experiment 3] Quantum vs Classical detection performance sweep...")
    q_error_probs, c_error_probs = [], []

    for clutter in noise_range:
        p_present = lab.quantum_detect(reflectivity=reflectivity, clutter_noise=clutter)
        p_absent = lab.quantum_detect(reflectivity=0.0, clutter_noise=clutter)  # no target = pure background
        # optimal-threshold binary hypothesis error (standard detection-theory form)
        q_error = 0.5 * (1.0 - abs(p_present - p_absent))
        q_error_probs.append(np.clip(q_error, 0.0, 0.5))

        c_present = lab.classical_detect(reflectivity=reflectivity, clutter_noise=clutter)
        c_absent = lab.classical_detect(reflectivity=0.0, clutter_noise=clutter)
        c_error = 0.5 * (1.0 - abs(c_present - c_absent))
        c_error_probs.append(np.clip(c_error, 0.0, 0.5))

        print(f"    clutter={clutter:.3f}  ->  Q_error={q_error:.4f}   C_error={c_error:.4f}")

    return np.array(q_error_probs), np.array(c_error_probs)


## %% [Cell 6] ----------------------------------------------------------------
# PLOTTING
# ------------------------------------------------------------------------------
def make_plots(noise_levels, chsh_values, concurrence_values,
               noise_range, q_error_probs, c_error_probs):

    plt.rcParams.update({
        "font.size": 11,
        "figure.figsize": (9, 5.5),
        "axes.edgecolor": "#333333",
        "axes.grid": True,
        "grid.alpha": 0.3,
    })

    # --- Plot 1: CHSH vs noise ---
    fig1, ax1 = plt.subplots()
    ax1.plot(noise_levels, chsh_values, color="#1D3557", marker="o", linewidth=2.5, label="Measured CHSH $S$")
    ax1.axhline(2.0, color="#E63946", linestyle="--", linewidth=2, label="Classical bound (S = 2)")
    ax1.axhline(2 * np.sqrt(2), color="#2A9D8F", linestyle=":", linewidth=2, label=r"Tsirelson bound (S = $2\sqrt{2}$)")
    ax1.set_title("CHSH Correlation Statistic vs. Channel Noise", fontsize=13, fontweight="bold")
    ax1.set_xlabel("Depolarizing probability on signal qubit")
    ax1.set_ylabel("CHSH $S$ value")
    ax1.legend(loc="lower left", frameon=True)
    fig1.tight_layout()
    fig1.savefig("plot_1_chsh_vs_noise.png", dpi=300)
    plt.close(fig1)

    # --- Plot 2: Concurrence decay ---
    fig2, ax2 = plt.subplots()
    ax2.plot(noise_levels, concurrence_values, color="#6A4C93", marker="s", linewidth=2.5)
    ax2.set_title("Entanglement (Concurrence) Decay Under Noise", fontsize=13, fontweight="bold")
    ax2.set_xlabel("Depolarizing probability on signal qubit")
    ax2.set_ylabel("Concurrence  (1 = max entangled, 0 = separable)")
    ax2.set_ylim(-0.05, 1.05)
    fig2.tight_layout()
    fig2.savefig("plot_2_concurrence_decay.png", dpi=300)
    plt.close(fig2)

    # --- Plot 3: Quantum vs Classical detection error (THE key plot for slide 4) ---
    fig3, ax3 = plt.subplots()
    ax3.plot(noise_range, c_error_probs, color="#E63946", linestyle="--", marker="o",
             linewidth=2.5, markersize=6, label="Classical detection")
    ax3.plot(noise_range, q_error_probs, color="#1D3557", linestyle="-", marker="s",
             linewidth=3, markersize=6, label="Quantum (entangled) detection")
    ax3.fill_between(noise_range, q_error_probs, c_error_probs,
                      where=(c_error_probs > q_error_probs),
                      color="#A8DADC", alpha=0.4, label="Quantum advantage region")
    ax3.set_title("Target-Detection Error Probability: Quantum vs Classical", fontsize=13, fontweight="bold")
    ax3.set_xlabel("Background clutter / noise intensity")
    ax3.set_ylabel(r"Detection error probability $P_{error}$")
    ax3.set_ylim(0.0, 0.55)
    ax3.legend(loc="upper left", frameon=True)
    fig3.tight_layout()
    fig3.savefig("plot_3_quantum_vs_classical_error.png", dpi=300)
    plt.close(fig3)

    print("\n[INFO] Saved plots:")
    print("   plot_1_chsh_vs_noise.png")
    print("   plot_2_concurrence_decay.png")
    print("   plot_3_quantum_vs_classical_error.png")


